generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "sqlite"
url      = env("DATABASE_URL")
}

model Template {
  id           Int        @id @default(autoincrement())
  name         String
  departmentId Int?
  content      String
  filePath     String?
  placeholders String?
  createdAt    DateTime   @default(now())

  department   Department? @relation(fields: [departmentId], references: [id])
  documents    Document[]
}

model Document {
  id                  Int       @id @default(autoincrement())
  templateId          Int
  documentName        String?
  departmentName      String
  departmentShortCode String
  departmentId        Int
  documentCode        String
  referenceNumber     String    @unique
  content             String
  filePath            String?
  metadata            String?
  createdAt           DateTime  @default(now())

  template            Template  @relation(fields: [templateId], references: [id])
  department          Department @relation(fields: [departmentId], references: [id])

  @@index([departmentShortCode])
  @@index([createdAt])
  @@index([documentCode])
}

model Department {
  id Int @id @default(autoincrement())

  name String @unique

  shortCode String @unique

  createdAt DateTime @default(now())

  templates Template[]
  documents Document[]
}



model ReferenceCounter {
  id                  Int    @id @default(autoincrement())
  departmentShortCode String
  documentCode        String
  currentValue        Int    @default(0)

  @@unique([departmentShortCode, documentCode])
}
